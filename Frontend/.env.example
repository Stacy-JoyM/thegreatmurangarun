# Supabase (Project Settings → API). Public anon key is safe for browser inserts guarded by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Must be non-empty: copy the anon (public) JWT from Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server-only key for API routes (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMS (server-side only)
# Supported now: africastalking
SMS_PROVIDER=africastalking
SMS_API_KEY=your_africastalking_api_key
SMS_USERNAME=your_africastalking_username
# Optional approved sender ID from provider dashboard
SMS_SENDER_ID=
